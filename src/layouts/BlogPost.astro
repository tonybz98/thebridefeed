---
import Base from './Base.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  faq?: { q: string; a: string }[];
  slug: string;
}
const { title, description, pubDate, updatedDate, heroImage, tags = [], faq = [], slug } = Astro.props;
const fmt = (d: Date) => new Intl.DateTimeFormat('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  mainEntityOfPage: `${SITE.url}/blog/${slug}/`,
  inLanguage: 'ro-RO',
};

const faqLd = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---
<Base title={`${title} · ${SITE.name}`} description={description} type="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  {faqLd && <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />}
  <article>
    <div class="container post-hero">
      <a href="/blog/" class="back-link">← toate articolele</a>
      <div class="post-meta" style="margin-top: 1.2rem; margin-bottom: 1.1rem;">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {updatedDate && <span>actualizat {fmt(updatedDate)}</span>}
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="lead mt-2">{description}</p>
    </div>
    {heroImage && (
      <div class="container">
        <img src={heroImage} alt={title} style="border-radius: var(--r-lg); aspect-ratio: 16/9; object-fit: cover; width: 100%;" />
      </div>
    )}
    <div class="container">
      <div class="prose mt-3"><slot /></div>
    </div>
    {faq.length > 0 && (
      <div class="container">
        <div class="prose mt-3">
          <h2>Întrebări frecvente</h2>
          <div class="faq">
            {faq.map((item) => (
              <details>
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    )}
    {tags.length > 0 && (
      <div class="container">
        <div class="prose">
          <div class="tag-row">{tags.map((t) => <span class="tag">#{t}</span>)}</div>
        </div>
      </div>
    )}
  </article>
  <section class="section section--tight">
    <div class="container center">
      <h2 class="h-md">Plănuiești nunta?</h2>
      <p class="lead" style="margin-inline: auto;">Spune-ne data și îți zicem pe loc dacă suntem liberi.</p>
      <a href="/#contact" class="btn btn-primary mt-2">Verifică disponibilitatea</a>
    </div>
  </section>
</Base>
