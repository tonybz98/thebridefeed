---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFab from '../components/WhatsappFab.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  bare?: boolean;
}
const { title, description, image, type, bare = false } = Astro.props;
---
<!doctype html>
<html lang="ro">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} />
    <slot name="head" />
  </head>
  <body>
    {!bare && <a class="skip-link" href="#main">Sari la conținut</a>}
    {!bare && <Header />}
    <main id="main"><slot /></main>
    {!bare && <Footer />}
    {!bare && <WhatsappFab />}
    {!bare && <CookieConsent />}
    {!bare && (
      <script>
        import { logEvent } from '../lib/store.js';
        if (!location.pathname.startsWith('/admin')) logEvent('view', location.pathname);
        document.addEventListener('click', (e) => {
          const t = e.target;
          const a = t && t.closest ? t.closest('a[href*="wa.me"]') : null;
          if (a) logEvent('wa_click', location.pathname);
        });
      </script>
    )}
  </body>
</html>
