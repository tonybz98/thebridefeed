---
import Base from '../layouts/Base.astro';
---
<Base title="Pagina nu există — the bride feed" description="Pagina căutată nu există.">
  <section class="section center" style="min-height: 55vh; display: grid; place-content: center;">
    <div class="container">
      <span class="eyebrow" style="justify-content: center;">404</span>
      <h1 class="h-lg">Momentul ăsta nu există.</h1>
      <p class="lead" style="margin-inline: auto;">Dar al tău, da. Hai înapoi la pagina principală.</p>
      <a href="/" class="btn btn-primary mt-2">Înapoi acasă</a>
    </div>
  </section>
</Base>
