---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) => new Intl.DateTimeFormat('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---
<Base
  title={`Blog — ${SITE.name}`}
  description="Ghiduri și idei pentru mirese: content de nuntă, reels, social media și cum să-ți trăiești ziua fără să ratezi niciun moment."
>
  <section class="section">
    <div class="container">
      <span class="eyebrow"><span class="live-dot" aria-hidden="true"></span>blog</span>
      <h1 class="h-lg">Idei pentru ziua ta</h1>
      <p class="lead mt-2">
        Ghiduri despre content de nuntă, reels și cum să-ți trăiești ziua fără să ratezi niciun moment.
      </p>
      <div class="post-list mt-3">
        {posts.map((p) => (
          <a class="post-card" href={`/blog/${p.id}/`}>
            <time datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
            <h3>{p.data.title}</h3>
            <p>{p.data.description}</p>
            <div class="tag-row">{p.data.tags.slice(0, 3).map((t) => <span class="tag">#{t}</span>)}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
