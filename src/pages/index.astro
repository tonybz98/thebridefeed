---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': SITE.url,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  image: `${SITE.url}/og-default.jpg`,
  email: SITE.email,
  telephone: SITE.phone,
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: 44.4268, longitude: 26.1025 },
    geoRadius: 200000,
    name: 'București și împrejurimi (~200 km)',
  },
  address: { '@type': 'PostalAddress', addressLocality: SITE.city, addressRegion: 'București', addressCountry: 'RO' },
  sameAs: [SITE.instagram, SITE.tiktok],
  priceRange: '€€',
};

const igHandle = '@' + SITE.instagram.split('/').filter(Boolean).pop();
const ttHandle = SITE.tiktok.split('/').filter(Boolean).pop();
const telHref = `tel:${SITE.phone.replace(/\s/g, '')}`;
---
<Base title={SITE.title} description={SITE.description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <!-- HERO -->
  <section class="section hero-section" style="padding-top: clamp(2.5rem, 6vw, 4.5rem);">
    <div class="container hero">
      <div class="hero-copy">
        <span class="eyebrow"><span class="live-dot" aria-hidden="true"></span>live · real-time wedding content</span>
        <h1 class="h-xl">Nunta ta,<br />postată <em class="accent">chiar azi</em>.</h1>
        <p class="lead mt-2">
          Stăm lângă tine toată ziua și transformăm momentele reale în reels, stories și clipuri,
          gata de postat înainte să se termine petrecerea.
        </p>
        <div class="hero-cta">
          <a href="/disponibilitate/" class="btn btn-primary">Verifică disponibilitatea</a>
          <a href="/portofoliu/" class="btn btn-ghost">Vezi portofoliul</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><b>same-day</b><span>livrare în ziua nunții</span></div>
          <div class="stat"><b>150+</b><span>clipuri &amp; poze</span></div>
          <div class="stat"><b>live</b><span>stories în direct</span></div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-phone">
          <div class="reel hero-screen">
            <div class="reel-bars"><i></i><i></i><i></i></div>
            <span class="reel-live"><span class="live-dot" aria-hidden="true" style="width:.5em;height:.5em;"></span>live · azi 14:32</span>
            <div class="reel-cap">clipa dinainte<br />de „da”.</div>
            <span class="reel-mark"><span class="live-dot" aria-hidden="true" style="width:.45em;height:.45em;"></span>the bride feed</span>
          </div>
          <span class="hero-chip hero-chip--tl"><span class="live-dot" aria-hidden="true" style="width:.5em;height:.5em;"></span>filmăm acum</span>
          <span class="hero-chip hero-chip--br">livrat same-day</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CE PRIMEȘTI -->
  <section class="section section--tight" id="ce-primesti">
    <div class="container">
      <span class="eyebrow">ce primești</span>
      <h2 class="h-lg" style="max-width: 20ch;">Mai mult decât o filmare. <em class="accent">Conținut care trăiește online.</em></h2>
      <div class="grid grid-4 mt-3">
        <div class="card"><h3>Reels în timp real</h3><p>Postăm direct de la eveniment, cât emoția e proaspătă și oamenii sunt încă acolo.</p></div>
        <div class="card"><h3>Stories live</h3><p>Ziua ta, în direct pe contul tău, moment cu moment, fără să ridici telefonul.</p></div>
        <div class="card"><h3>Clipuri &amp; poze</h3><p>Momentele mici, sincere, pe care fotograful clasic le ratează.</p></div>
        <div class="card"><h3>Livrare same-day</h3><p>Highlight-uri gata de postat înainte să pleci de la petrecere.</p></div>
      </div>
    </div>
  </section>

  <!-- PACHETE -->
  <section class="section" id="pachete">
    <div class="container">
      <span class="eyebrow">pachete</span>
      <h2 class="h-lg">Alege cât de mult vrei să postezi.</h2>
      <div class="grid grid-3 mt-3" style="align-items: stretch;">
        <div class="pkg">
          <h3>Essential</h3>
          <div class="pkg-price"><b>1.200 lei</b></div>
          <ul>
            <li>prezență 4-5 ore</li>
            <li>peste 10 stories în timp real</li>
            <li>5 reels</li>
            <li>50 cadre (foto + video)</li>
            <li>social media takeover</li>
          </ul>
          <a href="#contact" class="btn btn-ghost">Cere oferta</a>
        </div>
        <div class="pkg pkg--featured">
          <span class="pkg-tag">cel mai ales</span>
          <h3>Premium</h3>
          <div class="pkg-price"><b>1.700 lei</b></div>
          <ul>
            <li>prezență 8-9 ore</li>
            <li>peste 20 stories în timp real</li>
            <li>12 reels</li>
            <li>75 cadre (foto + video)</li>
            <li>social media takeover</li>
          </ul>
          <a href="#contact" class="btn btn-primary">Cere oferta</a>
        </div>
        <div class="pkg">
          <h3>Full Day</h3>
          <div class="pkg-price"><b>2.500 lei</b></div>
          <ul>
            <li>prezență full day</li>
            <li>peste 30 stories în timp real</li>
            <li>18 reels</li>
            <li>125 cadre (foto + video)</li>
            <li>social media takeover</li>
          </ul>
          <a href="#contact" class="btn btn-ghost">Cere oferta</a>
        </div>
      </div>
      <span class="feed-cap mt-2">Prețuri orientative. Pachetul final se adaptează nunții tale.</span>
    </div>
  </section>

  <!-- CUM FUNCȚIONEAZĂ -->
  <section class="section section--dark" id="cum-functioneaza">
    <div class="container">
      <span class="eyebrow">cum funcționează</span>
      <h2 class="h-lg">Trei pași, <em class="accent">zero stres.</em></h2>
      <div class="grid grid-3 mt-3">
        <div>
          <span class="card-num">01</span>
          <h3 class="h-md" style="margin: .5rem 0;">Rezervi data</h3>
          <p style="color: var(--on-ink-muted);">Ne scrii, verificăm disponibilitatea și blocăm ziua ta în calendar.</p>
        </div>
        <div>
          <span class="card-num">02</span>
          <h3 class="h-md" style="margin: .5rem 0;">Ziua nunții</h3>
          <p style="color: var(--on-ink-muted);">Venim, stăm discret lângă tine și filmăm tot. Tu doar te bucuri.</p>
        </div>
        <div>
          <span class="card-num">03</span>
          <h3 class="h-md" style="margin: .5rem 0;">Primești totul</h3>
          <p style="color: var(--on-ink-muted);">Reels, stories și clipuri livrate same-day, gata de postat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- REELS / FEED -->
  <section class="section section--tight" id="reels">
    <div class="container">
      <span class="eyebrow"><span class="live-dot" aria-hidden="true"></span>din feed</span>
      <h2 class="h-lg">Ultimele povești</h2>
      <p class="lead mt-2">Ultimele clipuri filmate la nunți, direct de pe Instagram și TikTok.</p>
      <div class="portfolio-grid mt-3" id="feed-grid" role="list">
        <p class="pf-empty">Se încarcă…</p>
      </div>
      <div class="hero-cta" style="margin-top: 1.8rem;">
        <a href="/portofoliu/" class="btn btn-primary">Vezi portofoliul complet</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALE -->
  <section class="section section--blush" id="testimoniale">
    <div class="container">
      <span class="eyebrow">ce spun miresele</span>
      <h2 class="h-lg">Emoția, încă din prima zi.</h2>
      <div class="grid grid-3 mt-3">
        <blockquote class="quote">
          <p>Aveam deja fotograf și videograf, dar reelsurile postate chiar în seara nunții au fost cele care au explodat. Prietenii ne scriau în timp real.</p>
          <footer>Andra &amp; Vlad · București</footer>
        </blockquote>
        <blockquote class="quote">
          <p>Nu a trebuit să-mi ating telefonul toată ziua și totuși contul meu era plin de momente. Exact ce mi-am dorit.</p>
          <footer>Maria · Snagov</footer>
        </blockquote>
        <blockquote class="quote">
          <p>Au prins exact lacrimile, râsetele, haosul frumos. Genul de clipuri pe care le revăd și acum.</p>
          <footer>Ioana &amp; Andrei · București</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container" style="max-width: 820px;">
      <span class="eyebrow">întrebări frecvente</span>
      <h2 class="h-lg">Ce vrei să știi.</h2>
      <div class="faq mt-3">
        <details>
          <summary>Care e diferența față de un videograf?</summary>
          <p>Videograful livrează un film cinematic în câteva săptămâni. Noi livrăm conținut vertical, autentic, gata de social media, chiar în ziua nunții. Cel mai bine funcționăm împreună, nu unul în locul celuilalt.</p>
        </details>
        <details>
          <summary>Când primesc materialele?</summary>
          <p>Primele reels și stories apar live, în timpul evenimentului. Restul materialelor le primești în 24-48 de ore.</p>
        </details>
        <details>
          <summary>Lucrați alături de fotograful și videograful meu?</summary>
          <p>Da, mereu. Stăm discret, ne coordonăm cu echipa ta foto-video și nu intrăm în cadrele lor.</p>
        </details>
        <details>
          <summary>Acoperiți și alte orașe?</summary>
          <p>Suntem din București și filmăm în București, Ilfov și pe o rază de ~200 km: Ploiești, Pitești, Brașov, Sinaia, Sibiu și împrejurimi. Pentru evenimente la distanță se adaugă transport și, după caz, cazare.</p>
        </details>
        <details>
          <summary>Cât costă?</summary>
          <p>Pachetele pornesc de la 1.200 lei și se adaptează în funcție de durată și de cât conținut vrei. Vezi secțiunea de pachete sau scrie-ne pentru o ofertă personalizată.</p>
        </details>
        <details>
          <summary>Cum rezerv?</summary>
          <p>Ne scrii cu data nunții, confirmăm disponibilitatea și blocăm ziua cu un avans. Locurile din sezon se ocupă repede.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section" id="contact">
    <div class="container">
      <div class="contact">
        <div class="contact-intro">
          <span class="eyebrow"><span class="live-dot" aria-hidden="true"></span>contact</span>
          <h2 class="h-lg">Hai să vorbim despre <em class="accent">nunta ta</em>.</h2>
          <p class="lead mt-2">Spune-ne data și locul nunții și îți răspundem repede, de obicei chiar în aceeași zi.</p>
          <a href="/disponibilitate/" class="btn btn-primary contact-cta">Verifică disponibilitatea</a>
        </div>
        <div class="contact-methods">
          <a class="contact-card" href={`mailto:${SITE.email}`}>
            <span class="contact-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span>
            <span class="contact-tx"><span class="contact-k">email</span><span class="contact-v">{SITE.email}</span></span>
            <span class="contact-arrow" aria-hidden="true">→</span>
          </a>
          <a class="contact-card" href={telHref}>
            <span class="contact-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6.5 3.5h3l1.5 4.5-2 1.2a12 12 0 0 0 5.3 5.3l1.2-2 4.5 1.5v3a2 2 0 0 1-2.2 2A16.5 16.5 0 0 1 4.5 5.7 2 2 0 0 1 6.5 3.5z"/></svg></span>
            <span class="contact-tx"><span class="contact-k">telefon</span><span class="contact-v">{SITE.phone}</span></span>
            <span class="contact-arrow" aria-hidden="true">→</span>
          </a>
          <a class="contact-card" href={SITE.instagram} target="_blank" rel="me noopener">
            <span class="contact-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg></span>
            <span class="contact-tx"><span class="contact-k">instagram</span><span class="contact-v">{igHandle}</span></span>
            <span class="contact-arrow" aria-hidden="true">→</span>
          </a>
          <a class="contact-card" href={SITE.tiktok} target="_blank" rel="me noopener">
            <span class="contact-ic"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.5 3c.3 2.2 1.5 3.5 3.6 3.7v2.5c-1.2.1-2.3-.3-3.5-1v5.4c0 3.4-2.5 5.9-5.7 5.9-2.9 0-5.2-2.2-5.2-5 0-3 2.4-5.1 5.6-4.8v2.6c-.4-.1-.9-.2-1.3-.2-1.3 0-2.3 1-2.3 2.3 0 1.4 1.1 2.4 2.4 2.4 1.5 0 2.6-1.1 2.6-2.9V3h3.2z"/></svg></span>
            <span class="contact-tx"><span class="contact-k">tiktok</span><span class="contact-v">{ttHandle}</span></span>
            <span class="contact-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { listPortfolio, subscribePortfolio } from '../lib/store.js';
    import { renderEmbeds } from '../lib/embeds.js';
    const grid = document.getElementById('feed-grid');
    async function load() { renderEmbeds(grid, (await listPortfolio()).slice(0, 4)); }
    load();
    subscribePortfolio(load);
  </script>
</Base>
